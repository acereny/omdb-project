<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Movie Search App</title>
  
  <style>
    /* Basic Reset */
    * { 
      box-sizing: border-box; 
      margin: 0; 
      padding: 0; 
    }

    body {
      font-family: Arial, sans-serif;
      background-color: #f9f9f9;
      color: #333;
    }

    header {
      background-color: #ffd6e0;
      padding: 20px;
      text-align: center;
      border-bottom: 2px solid #f0b8c8;
    }

    .container {
      width: 90%;
      max-width: 1000px;
      margin: 0 auto;
      padding-top: 20px;
    }

    /* Search Box - Less advanced CSS, simpler flexbox */
    .search-box {
      background-color: #ffd6e0;
      padding: 20px;
      border-radius: 5px;
      margin-bottom: 20px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .search-box div {
      flex: 1;
      min-width: 200px;
    }

    .search-box label {
      display: block;
      font-size: 14px;
      margin-bottom: 5px;
      font-weight: bold;
    }

    .search-box input, .search-box select {
      width: 100%;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 4px;
    }

    .search-box button {
      width: 100%;
      padding: 10px;
      background-color: #ce93d8;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 16px;
      font-weight: bold;
      margin-top: 10px;
    }

    .search-box button:hover {
      background-color: #ba68c8;
    }

    #message {
      text-align: center;
      margin: 10px 0;
      font-weight: bold;
    }

    /* Movies List using standard floats or simple flexbox instead of Grid */
    .movies-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-around;
    }

    .movie-card {
      width: 30%;
      background-color: #fff;
      border: 1px solid #ddd;
      margin-bottom: 20px;
      padding: 10px;
      text-align: center;
      cursor: pointer;
      border-radius: 5px;
    }

    .movie-card:hover {
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .movie-card img {
      width: 100%;
      height: 350px;
      object-fit: cover;
      background-color: #eee;
    }

    .movie-title {
      font-size: 16px;
      font-weight: bold;
      margin: 10px 0 5px;
    }

    /* Responsive adjustments without advanced CSS properties */
    @media (max-width: 768px) {
      .movie-card { width: 45%; }
    }
    @media (max-width: 480px) {
      .movie-card { width: 100%; }
    }

    /* Simple Modal */
    .modal {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background-color: rgba(0,0,0,0.7);
      z-index: 100;
    }

    .modal-content {
      background-color: #fff;
      width: 80%;
      max-width: 700px;
      margin: 50px auto;
      padding: 20px;
      border-radius: 5px;
      position: relative;
      display: flex;
      gap: 20px;
    }

    @media (max-width: 600px) {
      .modal-content { flex-direction: column; }
    }

    .modal-poster {
      width: 200px;
    }

    .modal-poster img {
      width: 100%;
    }

    .close-btn {
      position: absolute;
      top: 10px;
      right: 15px;
      font-size: 24px;
      cursor: pointer;
      font-weight: bold;
    }

    .pagination {
      text-align: center;
      margin: 20px 0 50px;
    }

    .pagination button {
      padding: 8px 16px;
      margin: 0 5px;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <header>
    <h1>🎬 Watch With Us</h1>
  </header>

  <div class="container">
    
    <div class="search-box">
      <div>
        <label for="searchInput">Movie Title</label>
        <input type="text" id="searchInput" placeholder="e.g. Inception">
      </div>
      <div>
        <label for="yearInput">Year (Optional)</label>
        <input type="number" id="yearInput" placeholder="2010">
      </div>
      <div>
        <label for="typeSelect">Type</label>
        <select id="typeSelect">
          <option value="">All</option>
          <option value="movie">Movie</option>
          <option value="series">Series</option>
        </select>
      </div>
      <button id="searchBtn">Search</button>
    </div>

    <div id="message"></div>
    
    <div class="movies-list" id="moviesList"></div>
    
    <div class="pagination" id="pagination"></div>

  </div>

  <!-- Modal for Movie Details -->
  <div class="modal" id="movieModal">
    <div class="modal-content">
      <span class="close-btn" id="closeBtn">&times;</span>
      <div class="modal-poster" id="modalPoster"></div>
      <div class="modal-info" id="modalInfo"></div>
    </div>
  </div>

  <script>
    // OMDB API Configuration
    const API_KEY = 'cafe7ef4';
    const BASE_URL = 'https://www.omdbapi.com/?apikey=' + API_KEY;

    // App State
    let currentState = {
      query: '',
      year: '',
      type: '',
      page: 1
    };

    // Cache to avoid unnecessary requests (Performance requirement)
    const apiCache = {};

    // DOM Elements
    const searchInput = document.getElementById('searchInput');
    const yearInput = document.getElementById('yearInput');
    const typeSelect = document.getElementById('typeSelect');
    const searchBtn = document.getElementById('searchBtn');
    const moviesList = document.getElementById('moviesList');
    const messageEl = document.getElementById('message');
    const paginationEl = document.getElementById('pagination');
    const movieModal = document.getElementById('movieModal');
    const closeBtn = document.getElementById('closeBtn');

    // Initialize App
    window.onload = function() {
      // Load saved state from LocalStorage
      const savedState = localStorage.getItem('movieApp_state');
      if (savedState) {
        currentState = JSON.parse(savedState);
        searchInput.value = currentState.query;
        yearInput.value = currentState.year;
        typeSelect.value = currentState.type;
        
        if (currentState.query !== '') {
          fetchMovies();
        }
      }
    };

    // Search Button Click Event
    searchBtn.addEventListener('click', function() {
      currentState.query = searchInput.value.trim();
      currentState.year = yearInput.value.trim();
      currentState.type = typeSelect.value;
      currentState.page = 1;

      if (currentState.query === '') {
        messageEl.innerText = 'Please enter a movie title!';
        messageEl.style.color = 'red';
        return;
      }

      saveState();
      fetchMovies();
    });

    // Save state to LocalStorage
    function saveState() {
      localStorage.setItem('movieApp_state', JSON.stringify(currentState));
    }

    // Fetch movies from API
    async function fetchMovies() {
      messageEl.innerText = 'Loading...';
      messageEl.style.color = 'black';
      moviesList.innerHTML = '';
      paginationEl.innerHTML = '';

      let url = BASE_URL + '&s=' + encodeURIComponent(currentState.query) + '&page=' + currentState.page;
      if (currentState.year) url += '&y=' + currentState.year;
      if (currentState.type) url += '&type=' + currentState.type;

      // Check cache first
      if (apiCache[url]) {
        displayMovies(apiCache[url]);
        return;
      }

      try {
        const response = await fetch(url);
        const data = await response.json();
        
        // Error handling
        if (data.Response === 'False') {
          messageEl.innerText = data.Error;
          messageEl.style.color = 'red';
        } else {
          apiCache[url] = data; // Save to cache
          displayMovies(data);
        }
      } catch (error) {
        messageEl.innerText = 'Network Error! Please try again.';
        messageEl.style.color = 'red';
      }
    }

    // Render movies to screen
    function displayMovies(data) {
      messageEl.innerText = '';
      
      let htmlContent = '';
      for (let i = 0; i < data.Search.length; i++) {
        let movie = data.Search[i];
        // Handle broken poster images simply
        let posterSrc = (movie.Poster !== 'N/A') ? movie.Poster : 'https://via.placeholder.com/210x315?text=No+Poster';
        
        htmlContent += `
          <div class="movie-card" onclick="openMovieDetails('${movie.imdbID}')">
            <img src="${posterSrc}" alt="${movie.Title}" onerror="this.src='https://via.placeholder.com/210x315?text=Error'">
            <div class="movie-title">${movie.Title}</div>
            <div>${movie.Year}</div>
            <div style="font-size: 12px; color: gray; margin-top: 5px;">${movie.Type.toUpperCase()}</div>
          </div>
        `;
      }
      moviesList.innerHTML = htmlContent;

      // Setup simple pagination
      setupPagination(data.totalResults);
    }

    // Pagination logic
    function setupPagination(totalResults) {
      const totalPages = Math.ceil(totalResults / 10);
      
      if (totalPages > 1) {
        let prevDisabled = (currentState.page === 1) ? 'disabled' : '';
        let nextDisabled = (currentState.page === totalPages) ? 'disabled' : '';

        paginationEl.innerHTML = `
          <button onclick="changePage(-1)" ${prevDisabled}>Previous</button>
          <span>Page ${currentState.page} of ${totalPages}</span>
          <button onclick="changePage(1)" ${nextDisabled}>Next</button>
        `;
      }
    }

    function changePage(direction) {
      currentState.page += direction;
      saveState();
      fetchMovies();
      window.scrollTo(0, 0); // Scroll to top
    }

    // Fetch and display single movie details
    async function openMovieDetails(imdbID) {
      movieModal.style.display = 'block';
      document.getElementById('modalPoster').innerHTML = 'Loading...';
      document.getElementById('modalInfo').innerHTML = '';

      let url = BASE_URL + '&i=' + imdbID + '&plot=full';

      try {
        let data;
        if (apiCache[imdbID]) {
          data = apiCache[imdbID];
        } else {
          const response = await fetch(url);
          data = await response.json();
          apiCache[imdbID] = data;
        }

        let posterSrc = (data.Poster !== 'N/A') ? data.Poster : 'https://via.placeholder.com/300x450?text=No+Poster';

        document.getElementById('modalPoster').innerHTML = `<img src="${posterSrc}" alt="${data.Title}">`;
        
        // Display required details: Title, Year, Genre, Director, Poster
        document.getElementById('modalInfo').innerHTML = `
          <h2>${data.Title} (${data.Year})</h2>
          <p><strong>Genre:</strong> ${data.Genre}</p>
          <p><strong>Director:</strong> ${data.Director}</p>
          <p><strong>Actors:</strong> ${data.Actors}</p>
          <p><strong>IMDB Rating:</strong> ${data.imdbRating}</p>
          <hr style="margin: 15px 0;">
          <p>${data.Plot}</p>
        `;

      } catch (error) {
        document.getElementById('modalInfo').innerHTML = '<p style="color:red;">Error loading details.</p>';
      }
    }

    // Close Modal
    closeBtn.addEventListener('click', function() {
      movieModal.style.display = 'none';
    });

    window.onclick = function(event) {
      if (event.target == movieModal) {
        movieModal.style.display = 'none';
      }
    };
  </script>

</body>
</html>
